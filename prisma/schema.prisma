generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  publicKey           String             @id
  name                String             @default("")
  bio                 String             @default("")
  pfpUrl              String             @default("")
  links               Json               @default("[]")
  balance             Float              @default(0)
  totalWinnings       Float              @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  reputationScore     Int                @default(500)
  reputationTier      String             @default("Intermediate")
  oracleReliability   Float?
  totalResolutions    Int                @default(0)
  disputedResolutions Int                @default(0)
  avgResolutionTime   Float?
  bets                Bet[]
  challenges          DisputeChallenge[]
  votes               DisputeVote[]
  liquidityRewards    LiquidityReward[]
  createdMarkets      Market[]           @relation("MarketCreator")
  transactions        Transaction[]

  @@index([reputationScore])
}

model Transaction {
  id            String   @id @default(cuid())
  userPublicKey String
  type          String
  amount        Float
  hash          String   @default("")
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userPublicKey], references: [publicKey])
}

model Market {
  id                  String               @id @default(cuid())
  title               String
  description         String?              @default("")
  creatorId           String
  openDate            DateTime             @default(now())
  closeDate           DateTime
  outcome             String?
  yesPool             Float                @default(0)
  noPool              Float                @default(0)
  totalVolume         Float                @default(0)
  contractMarketId    Int?                 @unique
  status              MarketStatus         @default(OPEN)
  qualityScore        Float?
  manipulationScore   Float                @default(0)
  minBetSize          Float                @default(10)
  incentiveMultiplier Float                @default(1.0)
  volatility          Float                @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  category            String               @default("Crypto")
  imageUrl            String?              @default("")
  oracleAddress       String?
  payoutBps           Int?                 @default(10000)
  bets                Bet[]
  challenges          DisputeChallenge[]
  riskFlags           ManipulationAlert[]
  creator             User                 @relation("MarketCreator", fields: [creatorId], references: [publicKey])
  probabilityHistory  ProbabilityHistory[]

  @@index([creatorId])
  @@index([status])
}

model Bet {
  id            String    @id @default(cuid())
  marketId      String
  userPublicKey String
  amount        Float
  commitment    String    @unique
  nullifier     String?   @unique
  revealed      Boolean   @default(false)
  txHash        String?
  claimedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  market        Market    @relation(fields: [marketId], references: [id])
  user          User      @relation(fields: [userPublicKey], references: [publicKey])

  @@index([marketId])
  @@index([userPublicKey])
  @@index([commitment])
  @@index([userPublicKey, marketId, createdAt])
  @@index([marketId, createdAt])
}

model ProbabilityHistory {
  id          String   @id @default(cuid())
  marketId    String
  probability Float
  confidence  Float
  sources     Json
  createdAt   DateTime @default(now())
  market      Market   @relation(fields: [marketId], references: [id])

  @@index([marketId, createdAt])
}

model DisputeChallenge {
  id              String        @id @default(cuid())
  marketId        String
  challengerId    String
  evidence        String
  proposedOutcome String
  bond            Float         @default(100)
  status          String        @default("PENDING")
  votingEndsAt    DateTime
  createdAt       DateTime      @default(now())
  challenger      User          @relation(fields: [challengerId], references: [publicKey])
  market          Market        @relation(fields: [marketId], references: [id])
  votes           DisputeVote[]

  @@index([marketId])
  @@index([status])
}

model DisputeVote {
  id        String           @id @default(cuid())
  disputeId String
  voterId   String
  outcome   String
  stake     Float
  weight    Float
  createdAt DateTime         @default(now())
  dispute   DisputeChallenge @relation(fields: [disputeId], references: [id])
  voter     User             @relation(fields: [voterId], references: [publicKey])

  @@unique([disputeId, voterId])
  @@index([disputeId])
}

model ManipulationAlert {
  id        String   @id @default(cuid())
  marketId  String
  flagType  String
  severity  String
  details   Json
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  market    Market   @relation(fields: [marketId], references: [id])

  @@index([marketId])
  @@index([severity, resolved])
}

model LiquidityReward {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime
  points    Float
  reward    Float?
  claimed   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [publicKey])

  @@index([userId, weekStart])
}

model WalletRelationship {
  id           String   @id @default(cuid())
  sourceWallet String
  targetWallet String
  relationship String
  confidence   Float
  createdAt    DateTime @default(now())

  @@unique([sourceWallet, targetWallet, relationship])
  @@index([sourceWallet])
  @@index([targetWallet])
  @@index([sourceWallet, relationship])
  @@index([targetWallet, relationship])
}

model SystemAlert {
  id        String   @id @default(cuid())
  type      String
  severity  String
  message   String
  metadata  Json
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([severity, resolved])
  @@index([createdAt])
}

enum MarketStatus {
  OPEN
  CLOSED
  RESOLVED
  DISPUTED
}
